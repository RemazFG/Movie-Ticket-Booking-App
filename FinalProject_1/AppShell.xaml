<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FinalProject_1.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:FinalProject_1"
    Title="Magic Cinema"
    FlyoutBackgroundColor="White"
    Shell.BackgroundColor="#1F1F1F"
    Shell.TitleColor="#ffb300"
    Shell.ForegroundColor="#ffb300"
    FlyoutBehavior="Flyout">

    <Shell.Resources>
        <Style TargetType="Label" Class="FlyoutItemLabelStyle">
            <Setter Property="TextColor" Value="White" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontAttributes" Value="Bold" />
        </Style>
    </Shell.Resources>

    <Shell.FlyoutHeader>
        <Grid HeightRequest="200">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#3a0070" Offset="0.1" />
                    <GradientStop Color="#121212" Offset="1.0" />
                </LinearGradientBrush>
            </Grid.Background>

            <VerticalStackLayout VerticalOptions="Center" Spacing="5" Padding="20">
                <Label Text="MAGIC" FontSize="32" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                <Label Text="CINEMA" FontSize="32" FontAttributes="Bold" TextColor="#ffb300" HorizontalOptions="Center" Margin="0,-10,0,0"/>

                <BoxView HeightRequest="2" WidthRequest="100" Color="#ffb300" Margin="0,15,0,0"/>
                <Label Text="Welcome Back" TextColor="Gray" FontSize="14" HorizontalOptions="Center" Margin="0,5,0,0"/>
            </VerticalStackLayout>
        </Grid>
    </Shell.FlyoutHeader>

    <FlyoutItem Title="Home" Icon="home.png">
        <ShellContent ContentTemplate="{DataTemplate local:MainPage}" />
    </FlyoutItem>

    <FlyoutItem Title="About Us" Icon="about.png">
        <ShellContent ContentTemplate="{DataTemplate local:AboutPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Log In" Icon="login.png">
        <ShellContent ContentTemplate="{DataTemplate local:LogInPage}" />
    </FlyoutItem>

    <Shell.FlyoutFooter>
        <VerticalStackLayout Padding="20">
            <Label Text="v1.0.0" TextColor="Gray" FontSize="12" HorizontalOptions="Center"/>
        </VerticalStackLayout>
    </Shell.FlyoutFooter>

</Shell>