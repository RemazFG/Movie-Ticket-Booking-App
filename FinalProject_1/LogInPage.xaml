<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinalProject_1.LogInPage"
             BackgroundColor="#121212"
             Title="Log In">

    <ScrollView>
        <VerticalStackLayout Spacing="25" Padding="30" VerticalOptions="Center">

            <Label Text="Welcome Back" FontSize="32" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
            <Label Text="Log in to your account" FontSize="16" TextColor="Gray" HorizontalOptions="Center"/>

            <VerticalStackLayout Spacing="5">
                <Label Text="Email" TextColor="#ffb300" FontAttributes="Bold" />
                <Entry x:Name="EmailEntry" Placeholder="Enter your email" 
                       TextColor="White" PlaceholderColor="#666" BackgroundColor="#222" TextChanged="OnEntryTextChanged" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="5">
                <Label Text="Password" TextColor="#ffb300" FontAttributes="Bold" />
                <Entry x:Name="PasswordEntry" Placeholder="Enter your password" IsPassword="True" 
                       TextColor="White" PlaceholderColor="#666" BackgroundColor="#222" TextChanged="OnEntryTextChanged" />
            </VerticalStackLayout>

            <Button x:Name="LogInButton" Text="Log In" Clicked="OnLogInClicked" IsEnabled="False"
                    BackgroundColor="#ffb300" TextColor="Black" FontAttributes="Bold" CornerRadius="10" HeightRequest="50" Margin="0,10,0,0"/>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                <Label Text="Don't have an account?" TextColor="White"/>
                <Label Text="Sign Up" TextColor="#ffb300" FontAttributes="Bold" TextDecorations="Underline">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSignUpClicked"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
