<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinalProject_1.AboutPage"
             BackgroundColor="#121212"
             Title="About Us">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Label Text="About Magic Cinema" FontSize="28" FontAttributes="Bold" TextColor="#ffb300" HorizontalOptions="Center" />

            <Image Source="cinemapicture.png" Aspect="AspectFill" HeightRequest="400" Clip="True"/>

            <Frame BackgroundColor="#222" BorderColor="#333" CornerRadius="10" Padding="15">
                <Label Text="Magic Cinema is distinguished as a premier local cinema brand, leading the entertainment sector with modern facilities. We are committed to introducing the latest cutting-edge technologies and diverse cinematic environments to provide an immersive experience for all patrons." 
                       TextColor="#E0E0E0" FontSize="16" LineHeight="1.5"/>
            </Frame>

            <Label Text="📍 Established Locally, World Class Experience." TextColor="#ffb300" HorizontalOptions="Center" FontAttributes="Italic"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>