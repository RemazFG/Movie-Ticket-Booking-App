<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinalProject_1.movieDetails"
             Title="Details" BackgroundColor="#121212">

    <ScrollView Margin="20">
        <VerticalStackLayout Padding="10" Spacing="20">
            <Image x:Name="moviPoster" 
                   Source="https://img.freepik.com/premium-psd/movie-poster_841014-31866.jpg" 
                   Aspect="AspectFill" HeightRequest="300" Clip="True"/>

            <Label x:Name="moviName" Text="Cyberpunk Adventure" FontSize="28" FontAttributes="Bold" TextColor="#ffb300"/>
            <Label x:Name="moviClass" Text="Sci-Fi | Action" FontSize="16" TextColor="Gray"/>
            <Label x:Name="moviStory" Text="A futuristic journey into the unknown..." TextColor="White"/>

            <BoxView Color="#333" HeightRequest="1"/>

            <Label Text="Select Branch" FontAttributes="Bold" TextColor="#ffb300"/>
            <Picker x:Name="BranchPicker" Title="Choose location" TextColor="White" TitleColor="Gray" BackgroundColor="#222">
                <Picker.Items>
                    <x:String>Dhahran Mall</x:String>
                    <x:String>Dammam Al Nagell Mall</x:String>
                    <x:String>West Avenue Mall</x:String>
                    <x:String>Riyadh Gallery</x:String>
                    <x:String>Jeddah Red Sea Mall</x:String>
                </Picker.Items>
            </Picker>

            <Label Text="Select Date" FontAttributes="Bold" TextColor="#ffb300"/>
            <DatePicker x:Name="MovieDatePicker" TextColor="White" MinimumDate="01/01/2025"/>

            <Label Text="Select Time" FontAttributes="Bold" TextColor="#ffb300"/>
            <VerticalStackLayout x:Name="TimeOptions" Spacing="10">
                <RadioButton Content="10:00 AM" GroupName="MovieTime" TextColor="White"/>
                <RadioButton Content="03:30 PM" GroupName="MovieTime" TextColor="White"/>
                <RadioButton Content="06:15 PM" GroupName="MovieTime" TextColor="White"/>
            </VerticalStackLayout>

            <Label Text="Tickets" FontAttributes="Bold" TextColor="#ffb300"/>
            <HorizontalStackLayout Spacing="15">
                <Label Text="Count:" TextColor="White" VerticalOptions="Center"/>
                <Stepper x:Name="TicketsStepper" Minimum="1" Maximum="10" Value="1" BackgroundColor="White"/>
                <Label x:Name="TicketsLabel" Text="1" TextColor="White" FontSize="18" FontAttributes="Bold" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="10" Margin="0,5,0,0">
                <Label Text="Total Price:" TextColor="Gray" FontSize="18" VerticalOptions="Center"/>
                <Label x:Name="TotalPriceLabel" Text="60.00 SAR" TextColor="#ffb300" FontSize="20" FontAttributes="Bold" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <Button x:Name="NextButton" Text="Next" Clicked="OnNextClicked"
                    BackgroundColor="Gray" TextColor="Black" FontAttributes="Bold" CornerRadius="10" HeightRequest="50"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>